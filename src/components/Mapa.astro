<section class="bg-bgDark1 scroll-mt-20 pt-6 pb-16 lg:pt-10 lg:pb-24" id="mapa">
  <div class="mapa-container">
    <div class="mx-auto mb-4 max-w-screen-sm text-center lg:mb-6">
      <h2
        class="mb-4 bg-gradient-to-r from-amber-300 to-green-600 bg-clip-text text-4xl font-extrabold tracking-tight text-transparent"
      >
        Ubicanos
      </h2>
      <p class="mb-4 font-light text-gray-500 sm:text-xl lg:mb-6 dark:text-gray-400">
        Eco Escuela Ser
      </p>
    </div>
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d761.0605527266985!2d-76.7490123!3d-11.9651361!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x49e18b5f4a001fab%3A0xfe508675d1792524!2sEco%20Escuela%20Soy%20Libre!5e1!3m2!1ses!2spe!4v1761530070992!5m2!1ses!2spe"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"></iframe>
  </div>
</section>

<style>
  /* MEDIA QUERY PARA MÓVILES (Max-width: 600px)
    Esto aplica a pantallas PEQUEÑAS
  */
  @media (max-width: 600px) {
    .mapa-container {
      /* Altura para móviles */
      height: 400px;

      /* Oculta desborde horizontal */
      overflow: hidden;
    }

    .mapa-container iframe {
      max-width: 100%;
    }
  }

  /* MEDIA QUERY PARA ESCRITORIO (Min-width: 601px)
    Esto aplica a pantallas GRANDES
  */
  @media (min-width: 601px) {
    .mapa-container {
      /* Altura para escritorio, evita que el footer desaparezca */
      height: 600px;

      /* Asegura que no haya desborde inesperado */
      overflow: hidden;
    }
  }
</style>
