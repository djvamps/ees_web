---
const FAQData = [
  {
    question: '¿Qué hace diferente a Eco Escuela Ser?',
    answer:
      'En Eco Escuela Ser creemos que cada niño aprende a su propio ritmo. Combinamos metodologías como Waldorf, Montessori y Asiri con experiencias en la naturaleza, fomentando la creatividad, la autonomía, el pensamiento crítico y el desarrollo emocional en un entorno de respeto y amor.',
  },
  {
    question: '¿Qué edades pueden formar parte de la escuela?',
    answer:
      'Nuestra propuesta educativa está diseñada para acompañar a niños en distintas etapas de desarrollo. Te invitamos a contactarnos para conocer los grupos disponibles, el proceso de admisión y encontrar el espacio más adecuado para tu hijo.',
  },
  {
    question: '¿Cómo se integran las actividades en la naturaleza?',
    answer:
      'La naturaleza es parte fundamental de nuestro aprendizaje. Los niños participan en huertos, exploración del entorno, cuidado de animales, actividades artísticas al aire libre y proyectos vivenciales que fortalecen su conexión con el mundo natural y consigo mismos.',
  },
  {
    question: '¿Cómo puedo agendar una visita o solicitar información?',
    answer:
      'Puedes comunicarte con nosotros a través de nuestro formulario de contacto, WhatsApp o redes sociales. Estaremos encantados de coordinar una visita para que conozcas nuestros espacios, metodología y comunidad educativa.',
  },
  {
    question: '¿Cómo acompañan el desarrollo emocional de los niños?',
    answer:
      'Promovemos un ambiente seguro y respetuoso donde los niños aprenden a reconocer y expresar sus emociones. A través del acompañamiento cercano de nuestros educadores, fortalecemos la autoestima, la empatía y la confianza en sí mismos.',
  },
  {
    question: '¿Participan las familias en la comunidad educativa?',
    answer:
      'Sí. Consideramos a las familias una parte esencial del proceso educativo. Organizamos encuentros, talleres, celebraciones y actividades comunitarias que fortalecen el vínculo entre la escuela, los niños y sus familias.',
  },
];
---

<section class="relative -mt-8 pt-12 pb-16 sm:mt-0 sm:pt-16">
  <div class="absolute -top-10" id="FAQ"></div>
  <div class="fade-in">
    <div class="relative z-10 container mx-auto w-11/12 px-2 sm:w-full sm:px-8 lg:px-4">
      <div class="mx-auto md:max-w-4xl">
        <p class="block-subtitle mb-7 text-center">Have any questions?</p>
        <h2 class="block-big-title mb-16 text-center">Preguntas Frecuentes</h2>
        <div class="-m-1 mb-11 flex flex-wrap">
          {
            FAQData.map((item, index) => (
              <div class="w-full p-1">
                <div
                  class="faq-box card mb-4 cursor-pointer rounded-3xl px-5 py-5 sm:px-8 sm:py-6"
                  data-open={index === 0 ? 'true' : 'false'}
                >
                  <button
                    type="button"
                    class="flex w-full cursor-pointer items-center justify-between bg-transparent text-left"
                    aria-expanded={index === 0 ? 'true' : 'false'}
                    aria-controls={`faq-panel-${index}`}
                    id={`faq-header-${index}`}
                  >
                    <h3 class="content-title">{item.question}</h3>
                    <svg
                      width="28px"
                      height="30px"
                      viewBox="0 0 20 20"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      class={`faq-chevron text-secondaryColor ml-4 shrink-0 transition-transform duration-300 ease-[cubic-bezier(0.4,0,0.2,1)] ${index === 0 ? 'rotate-[180deg]' : 'rotate-[270deg]'}`}
                      aria-hidden="true"
                    >
                      <path
                        d="M4.16732 12.5L10.0007 6.66667L15.834 12.5"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  </button>
                  <div
                    class={`faq-answer-grid ${index === 0 ? 'faq-open' : ''}`}
                    id={`faq-panel-${index}`}
                    role="region"
                    aria-labelledby={`faq-header-${index}`}
                  >
                    <div class="faq-answer-inner">
                      <p class="text-secondaryText pt-4">{item.answer}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-answer-grid {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 200ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 150ms ease;
  }
  .faq-answer-grid.faq-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  .faq-answer-inner {
    overflow: hidden;
    min-height: 0;
  }
</style>

<script>
  const initFaq = () => {
    document.querySelectorAll('.faq-box').forEach((box) => {
      const btn = box.querySelector('button');
      box.addEventListener('click', () => {
        const answerGrid = box.querySelector('.faq-answer-grid');
        const chevron = box.querySelector('.faq-chevron');
        const isOpen = box.getAttribute('data-open') === 'true';

        if (isOpen) {
          answerGrid?.classList.remove('faq-open');
          chevron?.classList.remove('rotate-[180deg]');
          chevron?.classList.add('rotate-[270deg]');
          box.setAttribute('data-open', 'false');
          btn?.setAttribute('aria-expanded', 'false');
        } else {
          answerGrid?.classList.add('faq-open');
          chevron?.classList.add('rotate-[180deg]');
          chevron?.classList.remove('rotate-[270deg]');
          box.setAttribute('data-open', 'true');
          btn?.setAttribute('aria-expanded', 'true');
        }
      });
    });
  };

  document.addEventListener('astro:page-load', initFaq);
</script>
