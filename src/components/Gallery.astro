---
// 1. Importa el componente Image de Astro
import { Image } from 'astro:assets';

// 2. Importa tus archivos reales de la carpeta src/assets/images/
import foto1 from '../assets/images/feature1.jpg'; // O el nombre correcto que desees mapear para foto1
import eco9 from '../assets/images/feature2.jpg'; // Mapea con tus archivos reales de la lista
import eco13 from '../assets/images/feature3.jpg';
import eco7 from '../assets/images/feature4.jpg';
import eco14 from '../assets/images/feature5.jpg';
import eco4 from '../assets/images/feature6.jpg';

// 3. Modifica tu arreglo para pasar las variables importadas en lugar de strings de texto
const slides = [
  {
    image: foto1,
    alt: 'Descripción de la imagen 1',
  },
  {
    image: eco9,
    alt: 'Descripción de la imagen 2',
  },
  {
    image: eco13,
    alt: 'Descripción de la imagen 3',
  },
  {
    image: eco7,
    alt: 'Descripción de la imagen 4',
  },
  {
    image: eco14,
    alt: 'Descripción de la imagen 5',
  },
  {
    image: eco4,
    alt: 'Descripción de la imagen 6',
  },
];

const totalPages = slides.length;
---

<section class="bg-bgDark2 w-full pt-24 pb-16 lg:pt-28 lg:pb-24" id="galery">
  <div class="fade-in">
    <div class="content-container">
      <div class="mb-12 max-w-2xl">
        <span class="block-subtitle mb-6 block">Actividades E.E.S.</span>
        <h2 class="block-big-title mb-6">Educar con amor, para un mundo consciente.</h2>
        <p class="text-secondaryText">Conectamos con la vida, con la tierra y con el ser.</p>
      </div>

      <div role="region" aria-roledescription="carousel" aria-label="Feature preview gallery">
        <div class="gallery-viewport relative">
          <button
            class="gallery-prev border-mainBorder bg-bgDark3 text-primaryText hover:bg-bgDark3Hover absolute top-1/2 -left-7 z-10 flex hidden h-14 w-14 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full border transition-colors duration-300 lg:flex"
            aria-label="Previous"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path d="M15 19l-7-7 7-7"></path>
            </svg>
          </button>
          <button
            class="gallery-next border-mainBorder bg-bgDark3 text-primaryText hover:bg-bgDark3Hover absolute top-1/2 -right-7 z-10 flex hidden h-14 w-14 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full border transition-colors duration-300 lg:flex"
            aria-label="Next"
          >
            <svg
              class="h-5 w-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path d="M9 5l7 7-7 7"></path>
            </svg>
          </button>
          <div class="overflow-hidden rounded-2xl">
            <div
              class="gallery-track flex transition-transform duration-500 ease-out"
              style="gap: 1.5rem;"
            >
              {
                [...slides, ...slides].map((slide) => (
                  <div class="gallery-slide bg-bgDark1Lighter border-mainBorderDarker flex aspect-[4/3] w-full shrink-0 items-center justify-center overflow-hidden rounded-xl border sm:w-[calc(50%-0.75rem)]">
                    {/* Se reemplazó el <svg> por la etiqueta <img> adaptada */}
                    <Image
                      src={slide.image}
                      alt={slide.alt}
                      class="h-full w-full object-cover"
                      loading="lazy"
                    />
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="mt-10 flex items-center justify-center gap-3">
          {
            Array.from({ length: totalPages }).map((_, i) => (
              <button
                class:list={[
                  'gallery-dot h-4 w-4 cursor-pointer rounded-full transition-all duration-300',
                  i === 0 ? 'bg-primaryText scale-100' : 'bg-secondaryText/30 scale-90',
                ]}
                data-dot-index={i}
                aria-label={`Go to page ${i + 1}`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const initGallery = () => {
    const track = document.querySelector<HTMLDivElement>('.gallery-track');
    const prev = document.querySelector<HTMLButtonElement>('.gallery-prev');
    const next = document.querySelector<HTMLButtonElement>('.gallery-next');
    const dots = document.querySelectorAll<HTMLButtonElement>('.gallery-dot');
    if (!track) return;

    const allSlides = track.querySelectorAll<HTMLDivElement>('.gallery-slide');
    const realCount = allSlides.length / 2; // half are clones
    let current = 0;
    let isTransitioning = false;
    const gap = 24;

    const getSlideStep = () => {
      return allSlides[0].offsetWidth + gap;
    };

    const setPosition = (index: number, animate: boolean) => {
      track!.style.transition = animate ? 'transform 500ms ease-out' : 'none';
      track!.style.transform = `translateX(-${index * getSlideStep()}px)`;
    };

    const updateDots = () => {
      const activeDot = ((current % realCount) + realCount) % realCount;
      dots.forEach((dot, i) => {
        if (i < realCount) {
          dot.classList.toggle('bg-primaryText', i === activeDot);
          dot.classList.toggle('scale-100', i === activeDot);
          dot.classList.toggle('bg-secondaryText/30', i !== activeDot);
          dot.classList.toggle('scale-90', i !== activeDot);
          (dot as HTMLElement).style.display = '';
        } else {
          (dot as HTMLElement).style.display = 'none';
        }
      });
    };

    const goBy = (delta: number) => {
      if (isTransitioning) return;
      isTransitioning = true;

      // Backward past 0: pre-jump to clone region, then animate
      if (current + delta < 0) {
        current += realCount;
        track!.style.transition = 'none';
        track!.style.transform = `translateX(-${current * getSlideStep()}px)`;
        void track!.offsetHeight;
      }

      current += delta;
      setPosition(current, true);
      updateDots();
    };

    track.addEventListener('transitionend', () => {
      // Forward past last real slide: post-jump to start
      if (current >= realCount) {
        current -= realCount;
        track!.style.transition = 'none';
        track!.style.transform = `translateX(-${current * getSlideStep()}px)`;
        void track!.offsetHeight;
      }
      isTransitioning = false;
    });

    prev?.addEventListener('click', () => goBy(-1));
    next?.addEventListener('click', () => goBy(1));

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        if (isTransitioning) return;
        const targetPage = Number(dot.dataset.dotIndex);
        current = targetPage;
        setPosition(current, true);
        updateDots();
        isTransitioning = true;
      });
    });

    // Swipe (touch + mouse drag)
    let startX = 0;
    let isDragging = false;

    const onDragStart = (x: number) => {
      startX = x;
      isDragging = true;
    };
    const onDragEnd = (x: number) => {
      if (!isDragging) return;
      isDragging = false;
      const diff = startX - x;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goBy(1);
        else goBy(-1);
      }
    };

    track.addEventListener('touchstart', (e) => onDragStart(e.touches[0].clientX), {
      passive: true,
    });
    track.addEventListener('touchend', (e) => onDragEnd(e.changedTouches[0].clientX));
    track.addEventListener('mousedown', (e) => {
      e.preventDefault();
      onDragStart(e.clientX);
    });
    window.addEventListener('mouseup', (e) => onDragEnd(e.clientX));

    window.addEventListener('resize', () => {
      setPosition(current, false);
      updateDots();
    });

    setPosition(0, false);
    updateDots();
  };

  document.addEventListener('DOMContentLoaded', initGallery);
  document.addEventListener('astro:page-load', initGallery);
</script>
