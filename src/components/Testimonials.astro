---
/**
 * Testimonials - Infinite horizontal marquee
 * Two rows scrolling in opposite directions, continuous loop.
 */
import { Image } from 'astro:assets';
import testimonial1 from '../assets/images/testimonial1.png';
import testimonial2 from '../assets/images/testimonial2.png';
import testimonial3 from '../assets/images/testimonial3.png';

const row1 = [
  {
  name: 'María Fernández',
  title: 'Madre de familia',
  content: 'Desde que mi hijo ingresó a Eco Escuela Ser, lo vemos más seguro, creativo y feliz. Ha desarrollado una gran conexión con la naturaleza y disfruta cada día de aprendizaje.',
image: testimonial2,
  rating: 5,
},

{
  name: 'Carlos Ramírez',
  title: 'Padre de familia',
  content: 'Nos enamoró la forma en que respetan el ritmo de cada niño. Aquí no solo aprenden contenidos, también fortalecen valores, autonomía y confianza en sí mismos.',
image: testimonial1,
  rating: 5,
},

{
  name: 'Andrea Gutiérrez',
  title: 'Madre de familia',
  content: 'La combinación de pedagogías libres y actividades al aire libre ha sido maravillosa para nuestra hija. Cada día regresa a casa con nuevas experiencias y entusiasmo.',
image: testimonial2,
  rating: 5,
},

{
  name: 'Luis Mendoza',
  title: 'Padre de familia',
  content: 'Encontramos un espacio donde nuestro hijo es escuchado, respetado y acompañado. El crecimiento emocional que hemos visto en él ha superado nuestras expectativas.',
image: testimonial3,
  rating: 5,
},

{
  name: 'Patricia Salazar',
  title: 'Madre de familia',
  content: 'La comunidad educativa es cálida y cercana. Sentimos que formamos parte de una gran familia comprometida con el bienestar y desarrollo integral de nuestros hijos.',
image: testimonial2,
  rating: 5,
},
];

const row2 = [
{
  name: 'Daniela Torres',
  title: 'Madre de familia',
  content: 'Eco Escuela Ser ha despertado la curiosidad natural de mi hija. Ahora explora, pregunta, crea y aprende con entusiasmo en un ambiente lleno de respeto y amor.',
image: testimonial2,
  rating: 5,
},

{
  name: 'Jorge Castillo',
  title: 'Padre de familia',
  content: 'Valoramos profundamente el enfoque humano de la escuela. Aquí los niños aprenden a convivir, cuidar la naturaleza y desarrollar su propio potencial.',
image: testimonial3,
  rating: 5,
},

{
  name: 'Rosa Herrera',
  title: 'Madre de familia',
  content: 'Las actividades en el huerto, el contacto con los animales y el aprendizaje vivencial han transformado la manera en que nuestro hijo entiende el mundo.',
image: testimonial2,
  rating: 5,
},

{
  name: 'Miguel Vargas',
  title: 'Padre de familia',
  content: 'Lo que más nos gusta es que fomentan el pensamiento crítico y la creatividad sin perder de vista los valores humanos. Es una educación verdaderamente integral.',
image: testimonial1,
  rating: 5,
},

{
  name: 'Verónica Paredes',
  title: 'Madre de familia',
  content: 'Cada educador demuestra un compromiso genuino con los niños. La confianza, sensibilidad y autonomía que nuestra hija ha desarrollado son el mejor testimonio.',
image: testimonial2,
  rating: 5,
},
];
---

<section class="bg-bgDark2 w-full overflow-hidden pt-8 pb-8 lg:pt-16 lg:pb-12">
  <div class="fade-in">
    <div class="block-subtitle mb-6 text-center">Testimonios</div>
    <div class="block-big-title mb-16 px-8 text-center sm:px-24 md:px-48">
      Historias que Inspiran
    </div>

    <!-- Row 1 - scrolls left -->
    <div class="marquee-container mb-6">
      <div class="marquee-track marquee-left">
        {
          [...row1, ...row1].map((t, i) => (
            <div
              class="marquee-card group card"
              {...(i >= row1.length ? { 'aria-hidden': 'true' } : {})}
            >
              <div class="mb-4 flex gap-0.5" role="img" aria-label={`${t.rating} out of 5 stars`}>
                {Array.from({ length: t.rating }).map(() => (
                  <svg
                    class="text-secondaryColor fill-secondaryColor h-4 w-4"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                  </svg>
                ))}
              </div>
              <p class="text-primaryText mb-6 text-[0.95rem] leading-relaxed">"{t.content}"</p>
              <div class="mt-auto flex items-center gap-3">
                <Image
                  src={t.image}
                  alt={t.name}
                  width={40}
                  height={40}
                  class="ring-mainBorderDarker rounded-full ring-1"
                  loading="eager"
                  decoding="sync"
                />
                <div>
                  <div class="text-primaryText text-sm font-semibold">{t.name}</div>
                  <div class="text-secondaryText text-xs">{t.title}</div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Row 2 - scrolls right -->
    <div class="marquee-container">
      <div class="marquee-track marquee-right">
        {
          [...row2, ...row2].map((t, i) => (
            <div
              class="marquee-card group card"
              {...(i >= row2.length ? { 'aria-hidden': 'true' } : {})}
            >
              <div class="mb-4 flex gap-0.5" role="img" aria-label={`${t.rating} out of 5 stars`}>
                {Array.from({ length: t.rating }).map(() => (
                  <svg
                    class="text-secondaryColor fill-secondaryColor h-4 w-4"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                  </svg>
                ))}
              </div>
              <p class="text-primaryText mb-6 text-[0.95rem] leading-relaxed">"{t.content}"</p>
              <div class="mt-auto flex items-center gap-3">
                <Image
                  src={t.image}
                  alt={t.name}
                  width={40}
                  height={40}
                  class="ring-mainBorderDarker rounded-full ring-1"
                  loading="eager"
                  decoding="sync"
                />
                <div>
                  <div class="text-primaryText text-sm font-semibold">{t.name}</div>
                  <div class="text-secondaryText text-xs">{t.title}</div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Fade edges -->
    <style>
      .marquee-container {
        position: relative;
        width: 100%;
      }
      .marquee-container::before,
      .marquee-container::after {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        width: 120px;
        z-index: 10;
        pointer-events: none;
      }
      .marquee-container::before {
        left: 0;
        background: linear-gradient(to right, rgb(40, 56, 16) 0%, transparent 100%);
      }
      .marquee-container::after {
        right: 0;
        background: linear-gradient(to left, rgb(40, 56, 16) 0%, transparent 100%);
      }

      .marquee-track {
        display: flex;
        gap: 1.5rem;
        width: max-content;
      }

      .marquee-left {
        animation: marqueeLeft 60s linear infinite;
      }
      .marquee-right {
        animation: marqueeRight 60s linear infinite;
      }

      .marquee-container:hover .marquee-track {
        animation-play-state: paused;
      }

      @keyframes marqueeLeft {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(-50%);
        }
      }
      @keyframes marqueeRight {
        0% {
          transform: translateX(-50%);
        }
        100% {
          transform: translateX(0);
        }
      }

      .marquee-card {
        flex-shrink: 0;
        width: 360px;
        padding: 1.5rem;
        border-radius: 1.25rem;
        display: flex;
        flex-direction: column;
        transition:
          border-color 0.5s ease,
          background-color 0.5s ease;
      }
    </style>
  </div>
</section>
